---
import { mainNavigation } from "../../lib/content/navigation";
import MobileMenu from "./MobileMenu.vue";
import Navigation from "./Navigation.astro";
---

<header class="sticky top-0 z-40 border-b border-green-900/20 bg-green-800 text-white shadow-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
    <a
      href="/"
      class="shrink-0 rounded text-lg font-bold tracking-wide outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-green-800"
      aria-label="Accueil AMTTA"
    >
      AMTTA
    </a>

    <Navigation items={mainNavigation} />
    <MobileMenu items={mainNavigation} />
  </div>
</header>
