---
import Layout from "../layouts/Layout.astro";

const quickLinks = [
  {
    label: "Entrainements",
    href: "/infos-pratiques/entrainements/",
    description: "Horaires, lieux et reperes pour pratiquer a Mions.",
  },
  {
    label: "Nous rejoindre",
    href: "/infos-pratiques/nous-rejoindre/",
    description: "Les prochaines etapes pour decouvrir ou rejoindre le club.",
  },
  {
    label: "Contact",
    href: "/contact/",
    description: "Une question sur l'inscription, les horaires ou la pratique.",
  },
  {
    label: "Vie sportive",
    href: "/vie-sportive/",
    description: "Activites, concours, photos et temps forts de la saison.",
  },
  {
    label: "Activites",
    href: "/vie-sportive/activites/",
    description: "Les moments club et sorties organises par saison.",
  },
  {
    label: "Concours",
    href: "/vie-sportive/concours/",
    description: "Resultats, tableaux et contenus lies aux competitions.",
  },
];

const journeyCards = [
  {
    eyebrow: "Familles",
    title: "Trouver les infos pratiques",
    text: "Comprendre rapidement ou pratiquer, quand venir, et comment poser une question au club.",
    href: "/infos-pratiques/entrainements/",
    cta: "Voir les entrainements",
  },
  {
    eyebrow: "Nouveaux archers",
    title: "Decouvrir le tir a l'arc",
    text: "Se projeter dans une pratique accessible, sportive et associative, sans jargon inutile.",
    href: "/pratique-du-tir-a-l-arc/",
    cta: "Decouvrir la pratique",
  },
  {
    eyebrow: "Membres",
    title: "Suivre la saison",
    text: "Retrouver les activites, concours, photos et liens utiles sans chercher dans plusieurs endroits.",
    href: "/vie-sportive/",
    cta: "Aller a la vie sportive",
  },
];

const seasonHighlights = [
  {
    title: "Saison 2025-2026",
    text: "Les informations utiles de reprise, les entrainements et les temps forts de la saison sont mis en avant depuis l'accueil.",
    href: "/infos-pratiques/entrainements/",
    cta: "Consulter les horaires",
  },
  {
    title: "Activites et concours",
    text: "Les contenus de vie sportive restent rattaches a la section Vie Sportive pour garder une navigation claire.",
    href: "/vie-sportive/concours/",
    cta: "Voir les concours",
  },
];

const resourceLinks = [
  { label: "Informations d'inscription", href: "/infos-pratiques/nous-rejoindre/" },
  { label: "Liens utiles", href: "/infos-pratiques/liens-utiles/" },
  { label: "Galerie vitrine", href: "/vie-sportive/galerie/" },
];
---

<Layout
  title="AMTTA Mions - Club de tir a l'arc"
  description="Site de l'Association Mions Tir a l'Arc : decouvrir le club AMTTA a Mions, consulter les entrainements, inscriptions, activites et concours."
  canonicalPath="/"
>
  <section class="bg-gradient-to-b from-green-50 via-white to-white">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-green-700">
          Association Mions Tir a l'Arc
        </p>
        <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-tight text-zinc-950 sm:text-5xl">
          Decouvrir, suivre et rejoindre l'AMTTA.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-zinc-700">
          Club de tir a l'arc a Mions, l'AMTTA accueille les archers et les curieux dans un cadre associatif simple,
          sportif et convivial.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/infos-pratiques/nous-rejoindre/"
            class="inline-flex items-center justify-center rounded-md bg-green-800 px-5 py-3 text-sm font-semibold text-white shadow-sm outline-none transition hover:bg-green-900 focus-visible:ring-2 focus-visible:ring-green-700 focus-visible:ring-offset-2"
          >
            Nous rejoindre
          </a>
          <a
            href="/infos-pratiques/entrainements/"
            class="inline-flex items-center justify-center rounded-md border border-green-800 px-5 py-3 text-sm font-semibold text-green-900 outline-none transition hover:bg-green-50 focus-visible:ring-2 focus-visible:ring-green-700 focus-visible:ring-offset-2"
          >
            Voir les entrainements
          </a>
        </div>
      </div>

      <div class="rounded-lg border border-green-900/10 bg-white p-5 shadow-sm">
        <div class="rounded-md bg-green-900 p-5 text-white">
          <p class="text-sm font-semibold text-green-100">Saison en cours</p>
          <h2 class="mt-2 text-2xl font-bold">2025-2026</h2>
          <p class="mt-3 text-sm leading-6 text-green-50">
            Retrouvez les horaires, les temps forts, les activites et les concours depuis des acces clairs.
          </p>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <a
            href="/vie-sportive/"
            class="rounded-md border border-green-900/10 bg-green-50 p-4 text-sm outline-none transition hover:border-green-700 focus-visible:ring-2 focus-visible:ring-green-700"
          >
            <span class="font-semibold text-green-950">Vie sportive</span>
            <span class="mt-1 block text-zinc-700">La saison, les activites et les concours.</span>
          </a>
          <a
            href="/contact/"
            class="rounded-md border border-amber-300 bg-amber-50 p-4 text-sm outline-none transition hover:border-amber-500 focus-visible:ring-2 focus-visible:ring-amber-500"
          >
            <span class="font-semibold text-zinc-950">Contact</span>
            <span class="mt-1 block text-zinc-700">Une question avant de venir au club.</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12" aria-labelledby="acces-rapides">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-green-700">Acces rapides</p>
        <h2 id="acces-rapides" class="mt-2 text-3xl font-bold text-zinc-950">Aller directement a la bonne information</h2>
      </div>
      <p class="max-w-xl text-sm leading-6 text-zinc-600">
        Les liens essentiels restent visibles des l'accueil, sans creer une page d'actualites a maintenir.
      </p>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        quickLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm outline-none transition hover:-translate-y-0.5 hover:border-green-700 hover:shadow-md focus-visible:ring-2 focus-visible:ring-green-700 focus-visible:ring-offset-2"
          >
            <span class="text-base font-semibold text-zinc-950">{link.label}</span>
            <span class="mt-2 block text-sm leading-6 text-zinc-600">{link.description}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="bg-zinc-50">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-green-700">Parcours</p>
        <h2 class="mt-2 text-3xl font-bold text-zinc-950">Une entree claire pour chaque besoin</h2>
        <p class="mt-4 text-base leading-7 text-zinc-700">
          L'accueil oriente les familles, les nouveaux archers et les membres vers les contenus stables du site.
        </p>
      </div>

      <div class="grid gap-4">
        {
          journeyCards.map((card) => (
            <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-green-700">{card.eyebrow}</p>
              <h3 class="mt-2 text-xl font-bold text-zinc-950">{card.title}</h3>
              <p class="mt-2 text-sm leading-6 text-zinc-600">{card.text}</p>
              <a
                href={card.href}
                class="mt-4 inline-flex rounded text-sm font-semibold text-green-800 underline-offset-4 outline-none hover:underline focus-visible:ring-2 focus-visible:ring-green-700 focus-visible:ring-offset-2"
              >
                {card.cta}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12" aria-labelledby="temps-forts">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-green-700">Temps forts</p>
        <h2 id="temps-forts" class="mt-2 text-3xl font-bold text-zinc-950">La vie du club, sans fil d'actualites permanent</h2>

        <div class="mt-6 grid gap-4">
          {
            seasonHighlights.map((item) => (
              <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
                <h3 class="text-lg font-bold text-zinc-950">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-600">{item.text}</p>
                <a
                  href={item.href}
                  class="mt-4 inline-flex rounded text-sm font-semibold text-green-800 underline-offset-4 outline-none hover:underline focus-visible:ring-2 focus-visible:ring-green-700 focus-visible:ring-offset-2"
                >
                  {item.cta}
                </a>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="rounded-lg border border-green-900/10 bg-green-50 p-5">
        <h3 class="text-xl font-bold text-zinc-950">Agenda et documents utiles</h3>
        <p class="mt-3 text-sm leading-6 text-zinc-700">
          Les informations pratiques restent accessibles depuis l'accueil. L'agenda complet et les documents finaux
          seront integres dans les stories dediees.
        </p>
        <div class="mt-5 grid gap-3">
          <a
            href="/vie-sportive/"
            class="rounded-md bg-white p-4 text-sm font-semibold text-green-900 shadow-sm outline-none transition hover:bg-green-100 focus-visible:ring-2 focus-visible:ring-green-700"
          >
            Acceder aux temps forts de la saison
          </a>
          {
            resourceLinks.map((item) => (
              <a
                href={item.href}
                class="rounded-md border border-green-900/10 bg-white p-4 text-sm font-semibold text-zinc-800 outline-none transition hover:border-green-700 focus-visible:ring-2 focus-visible:ring-green-700"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-green-950 text-white" aria-labelledby="photos-club">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-green-200">Photos recentes</p>
          <h2 id="photos-club" class="mt-2 text-3xl font-bold">Un club actif pendant les temps forts de la saison</h2>
          <p class="mt-4 text-base leading-7 text-green-50">
            L'accueil garde une presence photo sobre pour montrer la vie du club, sans devenir une galerie massive.
          </p>
          <a
            href="/vie-sportive/galerie/"
            class="mt-6 inline-flex rounded-md bg-white px-5 py-3 text-sm font-semibold text-green-950 outline-none transition hover:bg-green-100 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-green-950"
          >
            Voir la galerie vitrine
          </a>
        </div>

        <div class="grid gap-4 sm:grid-cols-3" aria-label="Apercu des photos du club">
          <div class="min-h-44 rounded-lg bg-gradient-to-br from-amber-200 via-orange-300 to-green-700 p-4 shadow-lg">
            <span class="rounded bg-white/90 px-2 py-1 text-xs font-semibold text-green-950">Entrainements</span>
          </div>
          <div class="min-h-44 rounded-lg bg-gradient-to-br from-sky-200 via-zinc-200 to-green-800 p-4 shadow-lg">
            <span class="rounded bg-white/90 px-2 py-1 text-xs font-semibold text-green-950">Concours</span>
          </div>
          <div class="min-h-44 rounded-lg bg-gradient-to-br from-green-200 via-emerald-400 to-zinc-800 p-4 shadow-lg">
            <span class="rounded bg-white/90 px-2 py-1 text-xs font-semibold text-green-950">Vie du club</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
