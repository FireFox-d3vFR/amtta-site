---
import "../styles/global.css";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";

interface Props {
  title?: string;
}

const { title = "AMTTA Mions" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-white text-zinc-950 antialiased">
    <a
      href="#contenu-principal"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-green-800 focus:shadow"
    >
      Aller au contenu principal
    </a>

    <Header />

    <main id="contenu-principal">
      <slot />
    </main>

    <Footer />
  </body>
</html>
